<svg xmlns="http://www.w3.org/2000/svg" width="1024" height="1024" viewBox="0 0 1024 1024">

  <!-- Warm gradient background -->
  <defs>
    <radialGradient id="bgGrad" cx="40%" cy="35%" r="70%">
      <stop offset="0%" stop-color="#FFF5F0"/>
      <stop offset="55%" stop-color="#FFECE3"/>
      <stop offset="100%" stop-color="#FDE8D8"/>
    </radialGradient>
    <radialGradient id="blob1" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#FF7A3D" stop-opacity="0.22"/>
      <stop offset="100%" stop-color="#FF7A3D" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Rounded square background -->
  <rect width="1024" height="1024" rx="224" fill="url(#bgGrad)"/>

  <!-- Decorative blob -->
  <ellipse cx="820" cy="180" rx="340" ry="340" fill="url(#blob1)"/>

  <!-- White icon card -->
  <rect x="262" y="262" width="500" height="500" rx="120"
