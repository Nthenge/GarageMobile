  <!-- Wrench left arm -->
  <rect x="400" y="330" width="48" height="130" rx="24" fill="#E8520A"/>
  <!-- Wrench right arm -->
  <rect x="576" y="330" width="48" height="130" rx="24" fill="#E8520A"/>
  <!-- Wrench crossbar -->
  <rect x="400" y="410" width="224" height="52" rx="26" fill="#E8520A"/>

  <!-- Bolt hole -->
  <circle cx="512" cy="640" r="36" fill="#E8520A"/>
  <circle cx="512" cy="640" r="18" fill="white" fill-opacity="0.9"/>

  <!-- Brand dot -->
  <circle cx="700" cy="700" r="28" fill="#E8520A"/>

</svg>
